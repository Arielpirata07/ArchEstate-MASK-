# Configuración de ArchEstate - Plantilla de ejemplo
# Copia este archivo a .env y completa los valores

# Clave secreta para Flask (genera una nueva con: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your-secret-key-here-change-in-production

# Configuración de base de datos (opcional - por defecto usa database.db en la raíz)
# DATABASE_PATH=database.db

# Configuración de producción (cambiar a 'true' para producción)
DEBUG=false